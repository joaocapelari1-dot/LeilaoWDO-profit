# ── Market Data Provider ──────────────────────────────────────────
# CEDRO  = usa Cedro Crystal (padrão atual)
# PROFIT = usa ProfitDLL via ProfitBridge
MARKET_PROVIDER=PROFIT

# ── Cedro (usado quando MARKET_PROVIDER=CEDRO) ────────────────────
CEDRO_HOST=datafeed1.cedrotech.com
CEDRO_PORT=81
CEDRO_USERNAME=
CEDRO_PASSWORD=

# ── ProfitBridge (usado quando MARKET_PROVIDER=PROFIT) ────────────
# URL do WebSocket do ProfitBridge rodando na VPS Windows
PROFIT_BRIDGE_URL=ws://SEU_VPS_IP:8787

# ── ProfitBridge Python (configurar no .env da VPS Windows) ───────
PROFIT_ACTIVATION_KEY=
PROFIT_USERNAME=
PROFIT_PASSWORD=
PROFIT_WS_PORT=8787
PROFIT_DLL_PATH=.\Win64\ProfitDLL.dll
# IMPORTANTE: usar contratos com vencimento explícito (não WDOFUT/DOLFUT)
# Atualizar a cada vencimento (3ª semana do mês)
# N=Julho, Q=Agosto, V=Outubro, Z=Dezembro
SYMBOLS=WDON26,DOLN26

# ── Anthropic ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Twelve Data ───────────────────────────────────────────────────
TWELVE_DATA_API_KEY=

# ── Sistema ───────────────────────────────────────────────────────
NODE_ENV=production
MOCK_MODE=false

